# sitemon environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Telegram (required for notifications) ---
SITEMON_TELEGRAM_BOT_TOKEN=your_bot_token_here
SITEMON_TELEGRAM_CHAT_ID=your_chat_id_here

# --- Server ---
SITEMON_SERVER_ADDR=:3000

# --- Check settings ---
SITEMON_CHECK_INTERVAL=30s
SITEMON_TIMEOUT=10s

# --- Storage ---
SITEMON_STORAGE_PATH=./sitemon.db

# --- Sites (optional, overrides sites in config.yaml) ---
# Format: "Name1|URL1|Status1,Name2|URL2|Status2"
# SITEMON_SITES=Google|https://www.google.com|200,GitHub|https://github.com|200
